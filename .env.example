# RecruitProof — Environment Configuration Template
# ----------------------------------------------------------------------------
# Copy to .env and edit values before running docker-compose up.
# NEVER commit your real .env file. The included .gitignore already excludes it.

# ---- License & Admin ----
RECRUITPROOF_LICENSE=your-license-key
RECRUITPROOF_ADMIN_PASSWORD=change-me
RECRUITPROOF_API_KEY=change-me-in-production

# ---- Storage ----
# Where RecruitProof stores candidate data, FAISS index, BM25 corpus, backups.
# Inside Docker, this is mounted at /data. On bare metal, point it anywhere.
RECRUITPROOF_DATA_DIR=/data

# ---- Embedding Model Cache ----
# HuggingFace model cache location. Defaults to a folder inside the data dir
# so the model survives container restarts.
HF_HOME=/data/.hf_cache

# ---- Optional: LLM Reasoning (DeepEvalAgent + ExplainAgent) ----
# Leave blank to use rule-based reasoning (the default, fully local-first).
# Set OPENAI_API_KEY to use GPT-4o-mini for richer one-sentence reasoning.
OPENAI_API_KEY=optional

# ---- Optional: Local Ollama LLM ----
# If you run Ollama locally (https://ollama.ai), set the base URL here.
# RecruitProof will auto-detect and use it for the DeepEval + Explain agents.
# Priority: OPENAI_API_KEY > OLLAMA_BASE_URL > rule-based.
OLLAMA_BASE_URL=http://localhost:11434

# ---- Optional: Backup Encryption ----
# AES-256-GCM key for encrypting backups. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank to disable backup encryption (NOT recommended for production).
BACKUP_ENCRYPTION_KEY=

# ---- Optional: S3 Backup Destination ----
# Leave blank to keep backups local only.
AWS_S3_BUCKET=
AWS_S3_PREFIX=recruitproof-backups
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
